# AuraBix Environment Variables Configuration
# Copy this file to .env.local and populate the keys

# Brevo API Key (or your Brevo SMTP password starting with "xsmtpsib-")
BREVO_API_KEY=your_brevo_api_key_or_smtp_password_here

# ── Prospect Analytics (Upstash Redis) ──
# Free tier: https://upstash.com — 10,000 commands/day
# Or add Redis via Vercel Dashboard → Storage → Create Redis Database
# Analytics works locally WITHOUT these keys (uses in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
